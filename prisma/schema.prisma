// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLIENT
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String   // Agency Name
  subscriptionPlan   String   @default("FREE")
  subscriptionStatus String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  
  razorpayCustomerId      String?
  razorpaySubscriptionId  String?
  
  razorpayKeyId           String?
  razorpayKeySecret       String?
  
  awsAccessKeyId          String?
  awsSecretAccessKey      String?
  awsRegion               String?
  awsS3BucketName         String?
  
  cancelledAt             DateTime?
  cancellationReason      String?
  

  users              User[]
  clientProfiles     ClientProfile[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  superAdminLogs     SuperAdminLog[]
}


model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String?
  image        String?
  passwordHash String
  role         Role           @default(CLIENT)
  resetOtp     String?
  resetOtpExpiry DateTime?
  availabilityStatus String   @default("ACTIVE") // ACTIVE, BUSY, AWAY
  tenantId     String?
  tenant       Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  clientProfile ClientProfile?
  messages      Message[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // MESSAGE, APPROVAL, INVOICE, PROJECT, SYSTEM
  title     String
  message   String
  link      String?
  sourceId  String?  // Original entity ID to prevent duplicates
  isRead    Boolean  @default(false)

  clientName String?
  clientId   String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@unique([userId, sourceId]) // Prevent duplicate notifications for same event
}

model SuperAdminLog {
  id        String   @id @default(uuid())
  action    String   
  message   String
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model ClientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  companyName String
  clientName  String
  website     String?
  industry    String?
  description String?
  audience    String?
  goals       String?
  locations   String?
  hours       String?
  phone       String?
  status      String   @default("ONBOARDED") // "ONBOARDED", "IN PROGRESS", "IN REVIEW", "COMPLETED", "ON HOLD"
  profileImageUrl String?
  
  slaAgreed       Boolean  @default(false)
  signature       String?
  agreedAt        DateTime?

  brandAssets         BrandAsset[]
  socialAccounts      SocialAccount[]
  competitors         Competitor[]
  contentRequirements ContentRequirement?
  questionnaire       Questionnaire?
  aiAnalysis          AIAnalysis?
  messages            Message[]
  projects            Project[]
  approvals           Approval[]
  invoices            Invoice[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandAsset {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  type            String        // e.g. "LOGO_DARK", "LOGO_LIGHT", "BRAND_GUIDELINES", "IMAGE", "VIDEO"
  fileUrl         String
  description     String?       // Optional description provided by the client
  
  createdAt       DateTime      @default(now())
}

model SocialAccount {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  platform        String
  url             String
}

model Competitor {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  name            String
  type            String        // e.g. "COMPETITOR", "ADMIRED_BRAND"
}

model ContentRequirement {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  postsPerMonth   Int?
  reelsPerMonth   Int?
  storiesPerMonth Int?
  languages       String?
  tone            String?
  hashtags        String?
  ctaPreference   String?
}

model Questionnaire {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  qna             Json          // [{ question: "...", answer: "..." }]
}

model AIAnalysis {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  summary         Json          // { brandVoice: [...], targetAudience: "...", coreServices: [...] }
}

model Message {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  senderId        String
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content         String
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Project {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  name            String        // e.g., "Website Redesign" or "Video Editing"
  stages          Json          // Array of strings: ["Design", "Frontend", "Backend", "Finished"]
  currentStageIdx Int           @default(0) // Index of the currently active stage
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Approval {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  items           ApprovalItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ApprovalItem {
  id          String   @id @default(uuid())
  approvalId  String
  approval    Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  
  fileUrl     String
  fileName    String
  fileType    String
  status      String   @default("PENDING") // PENDING | APPROVED | CHANGES_REQUESTED
  version     Int      @default(1)
  
  feedback    ApprovalFeedback[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApprovalFeedback {
  id             String       @id @default(uuid())
  approvalItemId String
  approvalItem   ApprovalItem @relation(fields: [approvalItemId], references: [id], onDelete: Cascade)
  
  action         String   // "APPROVED" | "CHANGES_REQUESTED" | "RESUBMITTED"
  comment        String?
  
  createdAt      DateTime @default(now())
}

model Invoice {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  title           String        // e.g., "Website Design - Phase 1", "Monthly Retainer - Jan 2026"
  amount          Float         // Amount in currency subunits (e.g. paisa/cents) or whole depending on your choice. Standard is usually subunits, let's keep it as standard float and we handle the x100 in Razorpay.
  currency        String        @default("INR") // INR, USD, etc.
  status          String        @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  type            String        @default("ONE_OFF") // ONE_OFF, RETAINER
  dueDate         DateTime?
  notes           String?
  
  razorpayOrderId   String?     // Stored when generated
  razorpayPaymentId String?     // Stored when paid
  
  items           InvoiceItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  rate        Float    
  amount      Float
}

