// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         Role           @default(CLIENT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  clientProfile ClientProfile?
}

model ClientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName String
  clientName  String
  website     String?
  industry    String?
  description String?
  audience    String?
  goals       String?
  locations   String?
  hours       String?
  phone       String?

  brandAssets         BrandAsset[]
  socialAccounts      SocialAccount[]
  competitors         Competitor[]
  contentRequirements ContentRequirement?
  questionnaire       Questionnaire?
  aiAnalysis          AIAnalysis?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandAsset {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  type            String        // e.g. "LOGO_DARK", "LOGO_LIGHT", "BRAND_GUIDELINES", "IMAGE", "VIDEO"
  fileUrl         String
  
  createdAt       DateTime      @default(now())
}

model SocialAccount {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  platform        String
  url             String
}

model Competitor {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  name            String
  type            String        // e.g. "COMPETITOR", "ADMIRED_BRAND"
}

model ContentRequirement {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  postsPerMonth   Int?
  reelsPerMonth   Int?
  storiesPerMonth Int?
  languages       String?
  tone            String?
  hashtags        String?
  ctaPreference   String?
}

model Questionnaire {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  qna             Json          // [{ question: "...", answer: "..." }]
}

model AIAnalysis {
  id              String        @id @default(uuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  
  summary         Json          // { brandVoice: [...], targetAudience: "...", coreServices: [...] }
}
